+const BG3_STEAM_ID = "1086940";
+let cachedDocumentsPath: string | undefined;
+
+/**
+ * Resolve BG3's Windows Local AppData directory on the host filesystem.
+ * Native Linux Vortex runs outside Proton, so Electron's localAppData points
+ * at ~/Local rather than at the game's Wine prefix.
+ */
+export function documentsPath(gamePath?: string) {
+  if (process.platform !== "win32" && gamePath !== undefined) {
+    const commonPath = path.dirname(gamePath);
+    const steamAppsPath = path.dirname(commonPath);
+    if (path.basename(commonPath) === "common" && path.basename(steamAppsPath) === "steamapps") {
+      cachedDocumentsPath = path.join(
+        steamAppsPath,
+        "compatdata",
+        BG3_STEAM_ID,
+        "pfx",
+        "drive_c",
+        "users",
+        "steamuser",
+        "AppData",
+        "Local",
+        "Larian Studios",
+        "Baldur's Gate 3",
+      );
+    }
+  }
+
+  return (
+    cachedDocumentsPath ??
+    path.join(util.getVortexPath("localAppData"), "Larian Studios", "Baldur's Gate 3")
+  );
 }
 
-export function modsPath() {
-  return path.join(documentsPath(), "Mods");
+export function modsPath(gamePath?: string) {
+  return path.join(documentsPath(gamePath), "Mods");
